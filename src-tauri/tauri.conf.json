{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "KNULL",
  "version": "1.0.3",
  "identifier": "com.xerqivon.knull",
  "build": {
    "beforeDevCommand": "npm start",
    "devUrl": "http://127.0.0.1:3000",
    "frontendDist": "https://xerqivon.onrender.com"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "KNULL",
        "width": 1220,
        "height": 760,
        "minWidth": 980,
        "minHeight": 640,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/256x256.png",
      "icons/icon.ico"
    ],
    "windows": {
      "digestAlgorithm": "sha256",
      "timestampUrl": "",
      "nsis": {
        "template": "nsis/installer.nsi",
        "installerIcon": "icons/icon.ico",
        "headerImage": "installer-assets/nsis-header.bmp",
        "sidebarImage": "installer-assets/nsis-sidebar.bmp",
        "installMode": "currentUser"
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEVEQTVDMTA5MjRGN0NERTMKUldUanpmY2tDY0dsN1h2djY4WThYajhYWDJhaW9UWW5hRFNuckFTRm94d2xieWh1WE1iUk81OWcK",
      "endpoints": [
        "https://xerqivon.onrender.com/updates/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
